# ⚠️  SECURITY: Copy this file to .env and fill in your own credentials
# NEVER commit the .env file to git

# ===============================================================================
# ENVIRONMENT
# ===============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# ===============================================================================
# DATABASE CONFIGURATION
# ===============================================================================
# For development: sqlite:///./reviews.db
# For production: postgresql://user:password@host:5432/dbname
DB_URL=sqlite:///./reviews.db
DB_ECHO_SQL=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# ===============================================================================
# EMBEDDING MODEL CONFIGURATION
# ===============================================================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2  # HuggingFace model
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu  # cpu, cuda, mps
EMBEDDING_CACHE_DIR=./.models

# ===============================================================================
# CLUSTERING CONFIGURATION
# ===============================================================================
CLUSTERING_N_THEMES=8
CLUSTERING_MIN_TOPIC_SIZE=5
CLUSTERING_LANGUAGE=english
CLUSTERING_UMAP_N_NEIGHBORS=15
CLUSTERING_UMAP_N_COMPONENTS=5
CLUSTERING_HDBSCAN_MIN_CLUSTER_SIZE=10

# ===============================================================================
# API CONFIGURATION
# ===============================================================================
API_TITLE=Review Discovery API
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_CORS_ORIGINS=["*"]
API_DEFAULT_LIMIT=50
API_MAX_LIMIT=500
API_DEFAULT_SEARCH_LIMIT=20
API_MAX_SEARCH_LIMIT=100
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=60

# ===============================================================================
# AUTHENTICATION CONFIGURATION
# ===============================================================================
AUTH_ENABLED=false
AUTH_SECRET_KEY=dev-secret-key-change-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE=30

# ===============================================================================
# DASHBOARD CONFIGURATION
# ===============================================================================
DASHBOARD_API_URL=http://localhost:8000
DASHBOARD_CACHE_TTL=300
DASHBOARD_THEME=light

# ===============================================================================
# LOGGING CONFIGURATION
# ===============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/app.log
LOG_USE_JSON=false

# ===============================================================================
# SCHEDULER CONFIGURATION
# ===============================================================================
SCHEDULER_ENABLED=false
SCHEDULER_COLLECTION_SCHEDULE="0 * * * *"  # Cron format
SCHEDULER_ANALYSIS_SCHEDULE="0 2 * * *"    # 2 AM daily

# ===============================================================================
# COLLECTORS CONFIGURATION (Optional)
# ===============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=review-discovery/1.0

